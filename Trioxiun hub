    secSpecial:AddLabel("Invisivel"):AddToggle({
        Default=false,Flag="Invisible",
        Callback=function(v)
            if v then
                if invisRunning then return end
                invisRunning=true
                local Player=LocalPlayer
                local Character=Player.Character
                if not Character then invisRunning=false return end
                Character.Archivable=true
                local Phantom=Character:Clone()
                for _,part in pairs(Phantom:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.Transparency=part.Name=="HumanoidRootPart" and 1 or 0.5
                    end
                end
                local savedCF=Character:FindFirstChild("HumanoidRootPart") and Character.HumanoidRootPart.CFrame
                Character.Parent=game:GetService("Lighting")
                Phantom.Parent=workspace
                local phantomHRP=Phantom:FindFirstChild("HumanoidRootPart")
                if savedCF and phantomHRP then phantomHRP.CFrame=savedCF end
                Player.Character=Phantom
                workspace.CurrentCamera.CameraSubject=Phantom:FindFirstChildOfClass("Humanoid") or Phantom
                task.wait(0.1)
                pcall(function() Player.Character.Animate.Disabled=true Player.Character.Animate.Disabled=false end)
                local IsInvis=true
                local syncConn=RunService.Heartbeat:Connect(function()
                    if not IsInvis then return end
                    pcall(function()
                        local pHRP=Phantom:FindFirstChild("HumanoidRootPart")
                        local cHRP=Character:FindFirstChild("HumanoidRootPart")
                        if pHRP and cHRP then cHRP.CFrame=pHRP.CFrame end
                    end)
                end)
                TurnVis_FN=function()
                    if not IsInvis then return end
                    IsInvis=false syncConn:Disconnect()
                    local curCF=Phantom:FindFirstChild("HumanoidRootPart") and Phantom.HumanoidRootPart.CFrame
                    Character.Parent=workspace
                    if curCF then
                        local origHRP=Character:FindFirstChild("HumanoidRootPart")
                        if origHRP then origHRP.CFrame=curCF end
                    end
                    Player.Character=Character
                    workspace.CurrentCamera.CameraSubject=Character:FindFirstChildOfClass("Humanoid") or Character
                    pcall(function() Phantom:Destroy() end)
                    task.wait(0.1)
                    pcall(function() Player.Character.Animate.Disabled=true Player.Character.Animate.Disabled=false end)
                    invisRunning=false
                end
                pcall(function()
                    Phantom:FindFirstChildOfClass("Humanoid").Died:Connect(function() pcall(TurnVis_FN) end)
                end)
                Logging.new("eye","Invisivel ativado!",5)
            else
                if TurnVis_FN then pcall(TurnVis_FN) end
                invisRunning=false
                Logging.new("eye","Visivel novamente!",3)
            end
        end
