-- ─── SERVIÇOS ───────────────────────────────────────────────────────────────
local Players          = game:GetService("Players")
local HttpService      = game:GetService("HttpService")
local RunService       = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService     = game:GetService("TweenService")
local LocalPlayer      = Players.LocalPlayer
local PlayerGui        = LocalPlayer:WaitForChild("PlayerGui")

-- ─── HWID ───────────────────────────────────────────────────────────────────
local function getHWID()
    return game:GetService("RbxAnalyticsService"):GetClientId()
end

-- ─── SALVAR / CARREGAR KEY ──────────────────────────────────────────────────
local function salvarKey(key)
    pcall(function() writefile(KEY_FILE, key) end)
end

local function carregarKeySalva()
    local ok, content = pcall(function() return readfile(KEY_FILE) end)
    if ok and content and content ~= "" then
        return content:gsub("%s+", "")
    end
    return nil
end

local function deletarKeySalva()
    pcall(function()
        if isfile(KEY_FILE) then delfile(KEY_FILE) end
    end)
end

-- ─── VERIFICAR KEY ──────────────────────────────────────────────────────────
local function verificarKey(inputKey)
    local hwid = getHWID()
    local success, response = pcall(function()
        return game:HttpGet(API_URL .. "/verificar?key=" .. inputKey .. "&hwid=" .. hwid)
    end)
    if not success then return false, "Erro ao conectar com a API." end
    local ok, data = pcall(function() return HttpService:JSONDecode(response) end)
    if not ok then return false, "Resposta invalida da API." end
    return data.valido, data.motivo
end

