    secSpecial:AddLabel("Ghost Mode"):AddToggle({
        Default=false,Flag="GhostMode",
        Callback=function(v)
            ghostAtivo=v
            local Camera=workspace.CurrentCamera
            local char=LocalPlayer.Character
            local hrp=char and char:FindFirstChild("HumanoidRootPart")
            local hum=char and char:FindFirstChildOfClass("Humanoid")
            if v then
                if hrp then
                    local a=Instance.new("BodyPosition")
                    a.Name="TruxiunGhostAnchor" a.Position=hrp.Position
                    a.MaxForce=Vector3.new(1e5,1e5,1e5) a.D=1000 a.Parent=hrp
                end
                if hum then hum.WalkSpeed=0 end
                ghostOrigCam=Camera.CameraType
                Camera.CameraType=Enum.CameraType.Scriptable
                UserInputService.MouseBehavior=Enum.MouseBehavior.LockCenter
                local camPos=Camera.CFrame.Position
                local camYaw,camPitch=0,0
                do local rx,ry=Camera.CFrame:ToOrientation() camPitch=rx camYaw=ry end
                local ghostSpeed=60
                ghostConn=RunService.Heartbeat:Connect(function(dt)
                    if not ghostAtivo then return end
                    local delta=UserInputService:GetMouseDelta()
                    camYaw=camYaw-delta.X*0.004
                    camPitch=math.clamp(camPitch-delta.Y*0.004,-math.rad(85),math.rad(85))
                    local rotCF=CFrame.fromEulerAnglesYXZ(camPitch,camYaw,0)
                    local dir=Vector3.zero
                    if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir=dir+rotCF.LookVector end
                    if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir=dir-rotCF.LookVector end
                    if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir=dir-rotCF.RightVector end
                    if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir=dir+rotCF.RightVector end
                    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir=dir+Vector3.new(0,1,0) end
                    if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir=dir-Vector3.new(0,1,0) end
                    if dir.Magnitude>0 then camPos=camPos+dir.Unit*ghostSpeed*dt end
                    Camera.CFrame=CFrame.new(camPos)*rotCF
                end)
                Logging.new("eye","Ghost Mode ativado!",6)
            else
                if ghostConn then ghostConn:Disconnect() ghostConn=nil end
                UserInputService.MouseBehavior=Enum.MouseBehavior.Default
                if hrp then local a=hrp:FindFirstChild("TruxiunGhostAnchor") if a then a:Destroy() end end
                if hum then hum.WalkSpeed=configFlags.WalkSpeed end
                Camera.CameraType=ghostOrigCam or Enum.CameraType.Custom
                Logging.new("eye","Ghost Mode desativado!",3)
            end
        end
