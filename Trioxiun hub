}
local function animarLoading(btn)
    local running = true
    local idx = 1
    task.spawn(function()
        while running do
            btn.Text = loadingTexts[idx]
            idx = idx % #loadingTexts + 1
            task.wait(0.35)
        end
    end)
    return function() running = false end
end

-- ─── SHAKE ───────────────────────────────────────────────────────────────────
local function shake(obj, offset)
    local orig = obj.Position
    for i = 1, 5 do
        obj.Position = orig + UDim2.new(0, i%2==0 and offset or -offset, 0, 0)
        task.wait(0.04)
    end
    obj.Position = orig
end

